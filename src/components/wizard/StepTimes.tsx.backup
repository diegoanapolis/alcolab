"use client"
import React, { useState, useEffect, useRef } from "react"
import { useForm } from "react-hook-form"
import { zodResolver } from "@hookform/resolvers/zod"
import { timesSchema, TimesData } from "@/lib/schemas"
import { Camera, Image as ImageIcon, Trash2, Plus } from "lucide-react"
import Link from "next/link"

type Replicate = { previewUrl: string; duration: number; fileName?: string; fileCreatedAt?: string; marks: Record<13|14|15|16|17|18, number|undefined>; volumesMarked: Array<13|14|15|16|17|18>; derived?: { points: Array<{x:number;y:number}>; slope: number; intercept: number; r2: number; estimatedTime: number } }

export default function StepTimes({ onNext, onBack, initialData }: { onNext: (data: TimesData) => void; onBack: () => void; initialData?: TimesData }) {
  const { handleSubmit, formState: { errors }, setValue, watch } = useForm<TimesData>({ 
    resolver: zodResolver(timesSchema), 
    defaultValues: initialData ?? { waterTimes: [], sampleTimes: [], deltaV: 4, hm: 7 } 
  })
  
  const waterTimes = watch("waterTimes") || []
  const sampleTimes = watch("sampleTimes") || []
  const deltaV = watch("deltaV")
  const hm = watch("hm")

  const [manualWaterInput, setManualWaterInput] = useState<string>("")
  const [manualSampleInput, setManualSampleInput] = useState<string>("")
  const [waterReplicates, setWaterReplicates] = useState<Array<Replicate>>([])
  const [sampleReplicates, setSampleReplicates] = useState<Array<Replicate>>([])
  const [customError, setCustomError] = useState<string | null>(null)

  // Timer Modal State
  const [showTimerModal, setShowTimerModal] = useState(false)
  const [timerTarget, setTimerTarget] = useState<"water"|"sample"|null>(null)
  const [timerRunning, setTimerRunning] = useState(false)
  const [elapsedMs, setElapsedMs] = useState(0)
  const startRef = useRef<number | null>(null)
  const timerIntRef = useRef<number | null>(null)

  const parseFlexibleDecimal = (input: string): number => {
    const s = String(input ?? "").trim()
    if (!s) return NaN
    const hasComma = s.includes(',')
    const hasDot = s.includes('.')
    let normalized = s
    if (hasComma && hasDot) normalized = s.replace(/\./g, '').replace(',', '.')
    else if (hasComma) normalized = s.replace(',', '.')
    const n = Number(normalized)
    return isNaN(n) ? NaN : n
  }

  // Load saved data on mount
  useEffect(() => {
    try {
      const wRaw = localStorage.getItem("videoReplicasWater")
      const sRaw = localStorage.getItem("videoReplicasSample")
      if (wRaw) setWaterReplicates(JSON.parse(wRaw))
      if (sRaw) setSampleReplicates(JSON.parse(sRaw))
      
      const wmRaw = localStorage.getItem("manualTimesWater")
      const smRaw = localStorage.getItem("manualTimesSample")
      if (wmRaw) setValue("waterTimes", JSON.parse(wmRaw))
      if (smRaw) setValue("sampleTimes", JSON.parse(smRaw))
    } catch {}
  }, [setValue])

  // Calculate times from video replicates
  const getVideoTimes = (replicates: Array<Replicate>): number[] => {
    return replicates
      .map(r => r.derived?.estimatedTime)
      .filter((t): t is number => typeof t === 'number' && !isNaN(t) && t > 0)
  }

  const waterVideoTimes = getVideoTimes(waterReplicates)
  const sampleVideoTimes = getVideoTimes(sampleReplicates)

  // Timer functions
  const openTimer = (target: "water"|"sample") => {
    setTimerTarget(target)
    setElapsedMs(0)
    setTimerRunning(false)
    setShowTimerModal(true)
  }

  const startTimer = () => {
    if (timerRunning) return
    setElapsedMs(0)
    startRef.current = typeof performance !== 'undefined' ? performance.now() : Date.now()
    setTimerRunning(true)
    timerIntRef.current = window.setInterval(() => {
      if (startRef.current != null) {
        const now = typeof performance !== 'undefined' ? performance.now() : Date.now()
        setElapsedMs(now - startRef.current)
      }
    }, 50)
  }

  const stopTimer = () => {
    if (!timerRunning) return
    setTimerRunning(false)
    if (timerIntRef.current != null) {
      clearInterval(timerIntRef.current)
      timerIntRef.current = null
    }
  }

  const saveTimer = () => {
    const val = Math.max(0, Math.round((elapsedMs/1000)*10)/10)
    if (!val || !timerTarget) return
    
    if (timerTarget === "water") {
      const next = [...waterTimes, val]
      setValue("waterTimes", next, { shouldValidate: true })
      try { localStorage.setItem("manualTimesWater", JSON.stringify(next)) } catch {}
    } else {
      const next = [...sampleTimes, val]
      setValue("sampleTimes", next, { shouldValidate: true })
      try { localStorage.setItem("manualTimesSample", JSON.stringify(next)) } catch {}
    }
    
    setShowTimerModal(false)
    setTimerTarget(null)
  }

  // Add manual time
  const addManualTime = (target: "water" | "sample") => {
    const raw = target === "water" ? manualWaterInput : manualSampleInput
    const val = parseFlexibleDecimal(raw)
    
    if (typeof val !== 'number' || isNaN(val) || val <= 0) {
      alert("Por favor, insira um tempo válido (ex: 12.45 ou 12,45)")
      return
    }

    if (target === "water") {
      const next = [...waterTimes, val]
      setValue("waterTimes", next, { shouldValidate: true })
      try { localStorage.setItem("manualTimesWater", JSON.stringify(next)) } catch {}
      setManualWaterInput("")
    } else {
      const next = [...sampleTimes, val]
      setValue("sampleTimes", next, { shouldValidate: true })
      try { localStorage.setItem("manualTimesSample", JSON.stringify(next)) } catch {}
      setManualSampleInput("")
    }
  }

  // Remove manual time
  const removeManualTime = (target: "water" | "sample", index: number) => {
    if (target === "water") {
      const next = waterTimes.filter((_, i) => i !== index)
      setValue("waterTimes", next, { shouldValidate: true })
      try { localStorage.setItem("manualTimesWater", JSON.stringify(next)) } catch {}
    } else {
      const next = sampleTimes.filter((_, i) => i !== index)
      setValue("sampleTimes", next, { shouldValidate: true })
      try { localStorage.setItem("manualTimesSample", JSON.stringify(next)) } catch {}
    }
  }

  // Calculate combined stats
  const getStats = (videoTimes: number[], manualTimes: number[]) => {
    const all = [...videoTimes, ...manualTimes]
    if (all.length === 0) return { count: 0, mean: 0 }
    const mean = all.reduce((sum, t) => sum + t, 0) / all.length
    return { count: all.length, mean }
  }

  const waterStats = getStats(waterVideoTimes, waterTimes)
  const sampleStats = getStats(sampleVideoTimes, sampleTimes)

  const validateReplicasBeforeNext = (): boolean => {
    setCustomError(null)
    const hasWater = (waterReplicates.length > 0) || (waterTimes.length > 0)
    const hasSample = (sampleReplicates.length > 0) || (sampleTimes.length > 0)
    
    if (!hasWater || !hasSample) {
      setCustomError("Necessário pelo menos um ensaio para Água e um para Amostra.")
      return false
    }
    
    return true
  }

  const submitHandler = handleSubmit((formData) => {
    if (!validateReplicasBeforeNext()) return
    
    // Save combined data
    try {
      const waterAll = [...waterVideoTimes, ...waterTimes]
      const sampleAll = [...sampleVideoTimes, ...sampleTimes]
      localStorage.setItem("finalWaterTimes", JSON.stringify(waterAll))
      localStorage.setItem("finalSampleTimes", JSON.stringify(sampleAll))
    } catch {}
    
    onNext(formData)
  })

  return (
    <form className="space-y-3 p-4" onSubmit={submitHandler}>
      <h1 className="text-xl font-bold">Instantes do escoamento (18 a 13 mL)</h1>
      
      {/* Instructions */}
      <div className="text-xs leading-tight text-neutral-700 text-justify space-y-1">
        <p>
          <span className="font-bold">Etapa mais sensível da metodologia</span>. Não deixe de consultar a{" "}
          <Link href="/metodologia" className="underline">Metodologia</Link> em caso de dúvida.
        </p>
        <ol className="list-decimal pl-5 space-y-1">
          <li>
            <span className="font-bold">Use seringa de 20 mL limpa e seca</span>, livre de detergente, 
            ou a enxágue com o líquido analisado.
          </li>
          <li>
            Deixe o cronômetro em posição de disparar em sua mão,{" "}
            <span className="font-bold">preencha a seringa (sem êmbulo) com o líquido analisado</span>, 
            por cima, até próximo à marcação de 20 mL e mantenha os seus olhos na altura do menisco 
            (parte inferior da curva que define o nível do líquido).
          </li>
          <li>
            Quando o menisco <span className="font-bold">encostar na graduação 15 mL</span>, dispare o 
            cronômetro imediatamente. Continue acompanhando o menisco e interrompa o menisco imediatamente 
            quando o menisco <span className="font-bold">tocar a marcação de 10 mL</span>.
          </li>
        </ol>
        <p>
          <span className="font-bold">Faça pelo menos dois escoamento (replicata)</span>. Se o recipiente 
          coletor estiver limpo e seco, você poderá reaproveitar o líquido.
        </p>
      </div>

      {/* Validation errors */}
      {(errors?.waterTimes || errors?.sampleTimes) && (
        <p className="text-red-600 text-sm">
          {errors?.waterTimes?.message || errors?.sampleTimes?.message as string}
        </p>
      )}
      {customError && <p className="text-red-600 text-sm">{customError}</p>}

      <p className="text-sm text-neutral-600">
        Use o mesmo bico/seringa; não bompeie o êmbulo. Observe o menisco à altura dos olhos. 
        Se perder o acionamento, complete o volume e refaça.
      </p>

      {/* Water and Sample Sections */}
      <div className="grid grid-cols-2 gap-4">
        {/* Water Section */}
        <div>
          <div className="font-medium mb-2" style={{ color: "var(--color-label)" }}>Água</div>
          
          {/* Video times summary */}
          {waterVideoTimes.length > 0 && (
            <div className="mb-2 text-sm text-neutral-600">
              {waterVideoTimes.length} vídeo(s) processado(s)
            </div>
          )}

          {/* Manual input */}
          <div className="space-y-2">
            <div className="font-medium text-sm">Inserção manual de tempo (s)</div>
            <input
              type="text"
              inputMode="decimal"
              placeholder="Tempo (s)"
              value={manualWaterInput}
              onChange={(e) => setManualWaterInput(e.target.value)}
              onKeyPress={(e) => e.key === 'Enter' && (e.preventDefault(), addManualTime("water"))}
              className="border rounded-lg p-2 w-full text-sm"
            />
            <div className="flex items-center gap-2">
              <button
                type="button"
                onClick={() => addManualTime("water")}
                className="border rounded-lg px-3 py-2 text-sm flex-1"
              >
                Adicionar
              </button>
              <button
                type="button"
                onClick={() => openTimer("water")}
                className="border rounded-lg px-3 py-2 text-sm flex-1"
              >
                Cronômetro
              </button>
            </div>

            {/* Manual times list */}
            {waterTimes.length > 0 && (
              <div className="mt-2 space-y-2">
                {waterTimes.map((t, i) => (
                  <div key={i} className="space-y-1">
                    <div className="px-3 py-2 border rounded-lg flex items-center justify-between">
                      <span className="text-xs">Replicata {waterReplicates.length + i + 1}</span>
                      <button
                        type="button"
                        className="text-xs underline text-red-600"
                        onClick={() => removeManualTime("water", i)}
                      >
                        Excluir
                      </button>
                    </div>
                    <div className="text-xs text-neutral-600">Tempo: {t.toFixed(2)} s</div>
                  </div>
                ))}
              </div>
            )}
          </div>

          {/* Stats */}
          <div className="mt-3 bg-blue-50 p-2 rounded text-sm">
            <div><strong>Total de repetições:</strong> {waterStats.count}</div>
            <div><strong>Tempo médio:</strong> {waterStats.mean > 0 ? waterStats.mean.toFixed(2) + 's' : '-'}</div>
          </div>
        </div>

        {/* Sample Section */}
        <div>
          <div className="font-medium mb-2" style={{ color: "var(--color-label)" }}>Amostra</div>
          
          {/* Video times summary */}
          {sampleVideoTimes.length > 0 && (
            <div className="mb-2 text-sm text-neutral-600">
              {sampleVideoTimes.length} vídeo(s) processado(s)
            </div>
          )}

          {/* Manual input */}
          <div className="space-y-2">
            <div className="font-medium text-sm">Inserção manual de tempo (s)</div>
            <input
              type="text"
              inputMode="decimal"
              placeholder="Tempo (s)"
              value={manualSampleInput}
              onChange={(e) => setManualSampleInput(e.target.value)}
              onKeyPress={(e) => e.key === 'Enter' && (e.preventDefault(), addManualTime("sample"))}
              className="border rounded-lg p-2 w-full text-sm"
            />
            <div className="flex items-center gap-2">
              <button
                type="button"
                onClick={() => addManualTime("sample")}
                className="border rounded-lg px-3 py-2 text-sm flex-1"
              >
                Adicionar
              </button>
              <button
                type="button"
                onClick={() => openTimer("sample")}
                className="border rounded-lg px-3 py-2 text-sm flex-1"
              >
                Cronômetro
              </button>
            </div>

            {/* Manual times list */}
            {sampleTimes.length > 0 && (
              <div className="mt-2 space-y-2">
                {sampleTimes.map((t, i) => (
                  <div key={i} className="space-y-1">
                    <div className="px-3 py-2 border rounded-lg flex items-center justify-between">
                      <span className="text-xs">Replicata {sampleReplicates.length + i + 1}</span>
                      <button
                        type="button"
                        className="text-xs underline text-red-600"
                        onClick={() => removeManualTime("sample", i)}
                      >
                        Excluir
                      </button>
                    </div>
                    <div className="text-xs text-neutral-600">Tempo: {t.toFixed(2)} s</div>
                  </div>
                ))}
              </div>
            )}
          </div>

          {/* Stats */}
          <div className="mt-3 bg-orange-50 p-2 rounded text-sm">
            <div><strong>Total de repetições:</strong> {sampleStats.count}</div>
            <div><strong>Tempo médio:</strong> {sampleStats.mean > 0 ? sampleStats.mean.toFixed(2) + 's' : '-'}</div>
          </div>
        </div>
      </div>

      {/* Parameters */}
      <div className="grid grid-cols-2 gap-4">
        <div>
          <label className="block text-sm font-medium mb-1">Volume escoado (mL)</label>
          <input
            type="number"
            step="0.1"
            min="0.1"
            className="border rounded-lg p-2 w-full text-sm"
            value={typeof deltaV === 'number' ? deltaV : 5}
            onChange={(e) => {
              const n = Number(e.target.value)
              if (!isNaN(n)) {
                setValue("deltaV", n, { shouldValidate: true })
                try { localStorage.setItem("deltaV", String(n)) } catch {}
              }
            }}
          />
        </div>
        <div>
          <label className="block text-sm font-medium mb-1">Altura média da coluna (cm)</label>
          <input
            type="number"
            step="0.1"
            min="0.1"
            className="border rounded-lg p-2 w-full text-sm"
            value={typeof hm === 'number' ? hm : 7}
            onChange={(e) => {
              const n = Number(e.target.value)
              if (!isNaN(n)) {
                setValue("hm", n, { shouldValidate: true })
                try { localStorage.setItem("hm", String(n)) } catch {}
              }
            }}
          />
        </div>
      </div>

      {/* Navigation */}
      <div className="flex gap-2 mt-4">
        <button type="button" onClick={onBack} className="border rounded-lg py-3 px-4 flex-1">
          Voltar
        </button>
        <button type="submit" className="bg-blue-600 hover:bg-blue-700 text-white rounded-lg py-3 px-4 flex-1">
          Próximo
        </button>
      </div>

      {/* Timer Modal */}
      {showTimerModal && (
        <div className="fixed inset-0 bg-white z-50 h-screen w-screen flex flex-col">
          <div className="p-3 flex items-center justify-between">
            <h2 className="text-base font-semibold">Cronômetro</h2>
            <button
              type="button"
              onClick={() => { setShowTimerModal(false); setTimerTarget(null); stopTimer() }}
              className="border rounded-lg py-1 px-2 text-xs"
            >
              Voltar
            </button>
          </div>
          <div className="flex-1 flex flex-col items-center justify-center gap-6 p-4">
            <div className="text-5xl font-bold font-mono">
              {(Math.round((elapsedMs/1000)*10)/10).toFixed(1)} s
            </div>
            <button
              type="button"
              onClick={() => { timerRunning ? stopTimer() : startTimer() }}
              className={`rounded-full w-52 h-52 text-xl font-bold ${
                timerRunning ? "bg-red-600 text-white" : "bg-green-600 text-white"
              }`}
            >
              {timerRunning ? "Parar" : "Disparar"}
            </button>
            {!timerRunning && elapsedMs > 0 && (
              <div className="flex gap-2">
                <button
                  type="button"
                  onClick={saveTimer}
                  className="bg-blue-600 hover:bg-blue-700 text-white rounded-lg py-3 px-4"
                >
                  Salvar tempo
                </button>
                <button
                  type="button"
                  onClick={() => { setElapsedMs(0) }}
                  className="border rounded-lg py-3 px-4"
                >
                  Descartar
                </button>
              </div>
            )}
          </div>
        </div>
      )}
    </form>
  )
}
